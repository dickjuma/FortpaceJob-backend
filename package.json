  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "prisma": "^6.19.2",
    "resend": "^6.9.3",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "winston": "^3.19.0"
  },
